#compdef nvflux

_nvflux() {
    local -a cmds
    cmds=(
        'ultra:Lock memory + GPU core clocks to maximum'
        'performance:Lock memory to highest tier'
        'balanced:Lock memory to mid-range tier'
        'powersave:Lock memory to lowest tier'
        'auto:Unlock all clocks (driver-managed)'
        'status:Show last saved profile'
        'clock:Print current memory clock in MHz'
        '--restore:Re-apply last saved profile'
        '--help:Show help'
        '--version:Print version'
    )
    _describe 'command' cmds
}

_nvflux "$@"
